// Dev build config. The Supabase anon key is PUBLISHABLE (RLS-gated) — safe to commit.
// Real server secrets (service_role, ANTHROPIC_API_KEY) live ONLY in Edge Function env.
// Host only (no scheme); AppConfig prepends https://.
SUPABASE_URL = your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-public-key
